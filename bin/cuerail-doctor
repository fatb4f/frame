(
  cd "$CUERAIL_HOME"
  cue vet -c=false ./cue/runtime "$review_packet_json" -d '#ReviewPacket'
) || die "invalid review packet output with token usage reference"
jq -e --arg path "$token_usage_json" '
  .tokenUsage.available == true and
  .tokenUsage.path == $path and
  .tokenUsage.source == "explicit" and
  .tokenUsage.evidence.schemaVersion == "cuerail.tokenUsageEvidence.v2" and
  .tokenUsage.evidence.usage.total == 101019 and
  .tokenUsage.evidence.observed.line == "Token usage: total=101,019 input=95,648 (+ 482,304 cached) output=5,371 (reasoning 1,620)"
' "$review_packet_json" >/dev/null ||
  die "invalid available review packet token usage reference"
rm -f "$token_usage_json" "$review_packet_json"
token_usage_json=
review_packet_json=

review_auto_dir="$doctor_fixture_state/review-auto"
mkdir -p "$review_auto_dir/.cuerail/evidence/token-usage"
token_usage_json="$review_auto_dir/.cuerail/evidence/token-usage/latest.json"
"$CUERAIL_HOME/bin/cuerail-token-usage" \
  --from-file "$CUERAIL_HOME/test/fixtures/token-usage/full.txt" \
  --run-id fixture-full \
  --exit-code 0 \
  >"$token_usage_json"
review_packet_json=$(mktemp "${TMPDIR:-/tmp}/cuerail-doctor-review-packet.XXXXXX.json")
(
  cd "$review_auto_dir"
  CUERAIL_HOME="$CUERAIL_HOME" CUERAIL_REVIEW_PACKET_SKIP_SOURCE_DOCTOR=1 "$CUERAIL_HOME/bin/cuerail-review-packet"
) >"$review_packet_json"
jq -e . "$review_packet_json" >/dev/null
(
  cd "$CUERAIL_HOME"
  cue vet -c=false ./cue/runtime "$review_packet_json" -d '#ReviewPacket'
) || die "invalid review packet output with auto token usage reference"
jq -e '
  .tokenUsage.available == true and
  .tokenUsage.path == ".cuerail/evidence/token-usage/latest.json" and
  .tokenUsage.source == "auto" and
  .tokenUsage.evidence.schemaVersion == "cuerail.tokenUsageEvidence.v2" and
  .tokenUsage.evidence.usage.total == 101019 and
  (.notes | index("token usage evidence auto-discovered from latest.json") != null)
