  index($0, "cuerail-doctor") {
    print root "/bin/cuerail-doctor:" NR ":" $0
    count += 1
    if (count >= max) exit
  }
' "$CUERAIL_HOME/bin/cuerail-doctor" |
  jq -R -s '[{type: "text", text: .}]' >"$rg_mcp_output_json"
