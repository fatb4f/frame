for fixture in "$CUERAIL_HOME"/test/fixtures/mcp/git-mcp-go/evidence/repos/*/*.json; do
  [ -f "$fixture" ] || continue
  rel_fixture=${fixture#"$CUERAIL_HOME"/}
  (
    cd "$CUERAIL_HOME"
    cue vet -c=false ./cue/runtime "$fixture" -d '#GitRepoCapture'
  ) || die "schema_invalid_git_repo_capture: $(basename "$fixture")"
  jq -e --arg path "$rel_fixture" '
    ($path | capture("^test/fixtures/mcp/git-mcp-go/evidence/repos/(?<repo>[^/]+)/(?<kind>[^/]+)\\.json$")) as $fixture |
    .repo.name == $fixture.repo and
    .kind == $fixture.kind and
    .evidence.cacheRel == ("mcp/git-mcp-go/evidence/repos/" + $fixture.repo + "/" + $fixture.kind + ".json") and
    (if (.kind | startswith("diff-")) then .kind == ("diff-" + .payload.scope) else true end)
  ' "$fixture" >/dev/null ||
    die "inconsistent_git_repo_capture_fixture: $rel_fixture"
done
