  [ -f "$fixture" ] || continue
  run_hook_fixture "$fixture" "$doctor_hardening_runtime/cuerail" "$doctor_hardening_turns"
done

hardening_events_dir="$doctor_hardening_turns/session-example/turn-example/events"
[ -d "$hardening_events_dir" ] || die "events directory missing after hardening replay"

expected_filenames='000001-user-prompt-submit.cue
000002-post-tool-use.some-other-tool.cue
000003-post-tool-use.mcp-ripgrep.cue
000004-pre-tool-use.cue
000005-post-tool-use.git-mcp-server.cue
000006-post-tool-use.another-tool.cue
000007-stop.cue'

actual_filenames=
hardening_count=0
for manifest in "$hardening_events_dir"/*.cue; do
  [ -f "$manifest" ] || continue
  base_name=${manifest##*/}
  hardening_count=$((hardening_count + 1))
  if [ -n "$actual_filenames" ]; then
    actual_filenames="${actual_filenames}
${base_name}"
  else
    actual_filenames=$base_name
  fi
done

[ "$hardening_count" -eq 7 ] ||
  die "wrong_count: got $hardening_count expected 7"

expected_seq=1
for manifest in "$hardening_events_dir"/*.cue; do
  [ -f "$manifest" ] || continue
  base_name=${manifest##*/}
  seq_text=${base_name%%-*}
  expected_seq_text=$(printf '%06d' "$expected_seq")
  [ "$seq_text" = "$expected_seq_text" ] ||
    die "sequence_gap: got $seq_text expected $expected_seq_text"
  expected_seq=$((expected_seq + 1))
done

[ "$actual_filenames" = "$expected_filenames" ] ||
  die "wrong_filename_set: got $(printf '%s' "$actual_filenames" | tr '\n' ' ')"

validate_manifest_schema "$hardening_events_dir/000001-user-prompt-submit.cue"
validate_manifest_schema "$hardening_events_dir/000002-post-tool-use.some-other-tool.cue"
validate_manifest_schema "$hardening_events_dir/000003-post-tool-use.mcp-ripgrep.cue"
validate_manifest_schema "$hardening_events_dir/000004-pre-tool-use.cue"
validate_manifest_schema "$hardening_events_dir/000005-post-tool-use.git-mcp-server.cue"
validate_manifest_schema "$hardening_events_dir/000006-post-tool-use.another-tool.cue"
validate_manifest_schema "$hardening_events_dir/000007-stop.cue"

assert_manifest_content "$hardening_events_dir/000001-user-prompt-submit.cue" "UserPromptSubmit" ""
assert_manifest_content "$hardening_events_dir/000002-post-tool-use.some-other-tool.cue" "PostToolUse" "some-other-tool"
assert_manifest_content "$hardening_events_dir/000003-post-tool-use.mcp-ripgrep.cue" "PostToolUse" "mcp-ripgrep"
assert_manifest_content "$hardening_events_dir/000004-pre-tool-use.cue" "PreToolUse" "mcp-ripgrep"
assert_manifest_content "$hardening_events_dir/000005-post-tool-use.git-mcp-server.cue" "PostToolUse" "git-mcp-server"
assert_manifest_content "$hardening_events_dir/000006-post-tool-use.another-tool.cue" "PostToolUse" "another-tool"
assert_manifest_content "$hardening_events_dir/000007-stop.cue" "Stop" ""

if [ "$mode" = "all" ]; then
  run_runtime_checks
fi

printf 'cuerail-doctor: git_read_source: available via git-mcp-go capture\n'
printf 'cuerail-doctor: rg_read_source: available via mcp-ripgrep capture\n'
printf 'cuerail-doctor: session_start_projection: green\n'
printf 'cuerail-doctor: pre_tool_use_projection: green\n'
printf 'cuerail-doctor: post_tool_use_projection: green\n'
printf 'cuerail-doctor: stop_projection: green\n'
printf 'cuerail-doctor: %s ok\n' "$mode"
