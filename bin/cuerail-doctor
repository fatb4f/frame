#!/usr/bin/env sh
set -eu

die() {
  printf 'cuerail-doctor: %s\n' "$1" >&2
  exit 1
}

need() {
  command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

: "${CODEX_HOME:?CODEX_HOME is required}"
: "${CODEX_STATE:?CODEX_STATE is required}"
: "${CUERAIL_HOME:=$CODEX_HOME/tools/cuerail}"

CUERAIL_STATE="${CUERAIL_STATE:-$CODEX_STATE/cuerail}"
CUERAIL_TURNS="${CUERAIL_TURNS:-$CUERAIL_STATE/turns}"

case "$CUERAIL_HOME" in
  "$CODEX_HOME"/tools/cuerail) ;;
  *) die "CUERAIL_HOME must be CODEX_HOME/tools/cuerail" ;;
esac

[ -d "$CUERAIL_HOME" ] || die "missing CUERAIL_HOME: $CUERAIL_HOME"
[ ! -L "$CUERAIL_HOME" ] || die "CUERAIL_HOME must not be a symlink"
[ -x "$CUERAIL_HOME/bin/cuerail-hook" ] || die "missing executable bin/cuerail-hook"
[ -x "$CUERAIL_HOME/bin/cuerail-doctor" ] || die "missing executable bin/cuerail-doctor"
[ -x "$CUERAIL_HOME/bin/cuerail-schema-sync" ] || die "missing executable bin/cuerail-schema-sync"
[ -d "$CUERAIL_HOME/cue" ] || die "missing active CUE package"

need cue
need awk
need cmp
need codex
need curl
need jq
need mktemp
need flock
need mkdir
need mv
need rm
need sed
need sha256sum
need tr
need wc

mkdir -p "$CUERAIL_TURNS"

(
  cd "$CUERAIL_HOME"
  cue vet ./cue
  cue export ./cue -e '#ExpectedHookSchemaFiles' >/dev/null
  cue export ./cue -e '#SchemaSync' >/dev/null
  cue export ./cue -e '#ExampleSchemaLock' >/dev/null
  cue export ./cue -e '#ExampleSessionStartHookOutput' >/dev/null
  cue export ./cue -e '#ExampleUserPromptSubmitHookOutput' >/dev/null
  cue export ./cue -e '#ExamplePostToolUseHookOutput' >/dev/null
  cue export ./cue -e '#ExampleStopHookOutput' >/dev/null
)

"$CUERAIL_HOME/bin/cuerail-schema-sync" --check >/dev/null

printf 'cuerail-doctor: ok\n'
