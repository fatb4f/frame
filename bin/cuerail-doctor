#!/usr/bin/env sh
set -eu
LC_ALL=C
export LC_ALL

die() {
  printf 'cuerail-doctor: %s\n' "$1" >&2
  exit 1
}

need() {
  command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

resolve_source_home() {
  case "$0" in
    */*) script_dir=${0%/*} ;;
    *)
      script_path=$(command -v "$0") || die "cannot locate script"
      script_dir=${script_path%/*}
      ;;
  esac

  cd "$script_dir/.." 2>/dev/null && pwd -P
}

check_node_version() {
  node_version=$(node --version | sed 's/^v//')
  node_major=${node_version%%.*}
  case "$node_major" in
    ''|*[!0-9]*) die "cannot parse node version: $(node --version)" ;;
  esac
  [ "$node_major" -ge 18 ] ||
    die "node >=18 required for mcp-ripgrep, got $(node --version)"
}

assert_ripgrep_mcp_config() {
  config_file="$CODEX_HOME/config.toml"
  expected_command="$CUERAIL_HOME/bin/cuerail-mcp-ripgrep"

  [ -f "$config_file" ] || die "missing Codex config: $config_file"

  awk -v expected_command="$expected_command" '
    /^\[mcp_servers\.ripgrep\]$/ { in_section = 1; next }
    /^\[/ && in_section { in_section = 0 }
    in_section && $0 == "command = \"" expected_command "\"" { command_ok = 1 }
    in_section && $0 == "env_vars = [\"PATH\", \"CODEX_HOME\", \"CODEX_STATE\", \"CUERAIL_HOME\", \"CUERAIL_BIN\", \"CUERAIL_STATE\"]" { env_ok = 1 }
    END { exit(command_ok && env_ok ? 0 : 1) }
  ' "$config_file" ||
    die "Codex MCP config missing canonical ripgrep runtime projection"
}

run_runtime_checks() {
  : "${CODEX_HOME:?CODEX_HOME is required}"
  : "${CODEX_STATE:?CODEX_STATE is required}"
  : "${CUERAIL_HOME:=$CODEX_HOME/tools/cuerail}"

  need awk
  need jq
  need node
  need rg
  need sed

  check_node_version

  wrapper="$CUERAIL_HOME/bin/cuerail-mcp-ripgrep"
  runtime_prefix="$CODEX_STATE/cuerail/mcp/mcp-ripgrep"
  runtime_bin="$runtime_prefix/node_modules/.bin/mcp-ripgrep"
  marker="$runtime_prefix/.cuerail-adapter.json"

  [ -x "$wrapper" ] || die "missing executable canonical wrapper: $wrapper"
  [ -x "$runtime_bin" ] || die "missing executable mcp-ripgrep package bin: $runtime_bin"
  [ -f "$marker" ] || die "missing mcp-ripgrep runtime marker: $marker"

  jq -e \
    --arg runtime_prefix "$runtime_prefix" \
    --arg runtime_bin "$runtime_bin" \
    --arg rg_path "$(command -v rg)" \
    '.name == "ripgrep" and
     .package == "mcp-ripgrep" and
     .version == "0.4.0" and
     .transport == "stdio" and
     .runtimePrefix == $runtime_prefix and
     .bin == $runtime_bin and
     .rg == $rg_path and
     (.node | type == "string" and startswith("v"))' \
    "$marker" >/dev/null ||
    die "invalid mcp-ripgrep runtime marker: $marker"

  assert_ripgrep_mcp_config
}

cleanup_temp_files() {
  [ -n "${output_json:-}" ] && rm -f "$output_json"
  [ -n "${stderr_log:-}" ] && rm -f "$stderr_log"
  [ -n "${fixture_wrap_json:-}" ] && rm -f "$fixture_wrap_json"
  [ -n "${fixture_persist_json:-}" ] && rm -f "$fixture_persist_json"
  [ -n "${mcp_adapter_json:-}" ] && rm -f "$mcp_adapter_json"
  [ -n "${expected_git_fixtures_json:-}" ] && rm -f "$expected_git_fixtures_json"
  [ -n "${expected_git_fixture_paths:-}" ] && rm -f "$expected_git_fixture_paths"
  [ -n "${actual_git_fixture_paths:-}" ] && rm -f "$actual_git_fixture_paths"
  [ -n "${generated_git_capture_paths:-}" ] && rm -f "$generated_git_capture_paths"
  [ -n "${git_status_payload_json:-}" ] && rm -f "$git_status_payload_json"
  [ -n "${git_unstaged_payload_json:-}" ] && rm -f "$git_unstaged_payload_json"
  [ -n "${git_staged_payload_json:-}" ] && rm -f "$git_staged_payload_json"
  [ -n "${generated_rg_capture_path:-}" ] && rm -f "$generated_rg_capture_path"
  [ -n "${rg_mcp_output_json:-}" ] && rm -f "$rg_mcp_output_json"
  [ -n "${token_usage_json:-}" ] && rm -f "$token_usage_json"
  [ -n "${manifest_json:-}" ] && rm -f "$manifest_json"
  [ -n "${review_packet_json:-}" ] && rm -f "$review_packet_json"
  [ -n "${doctor_fixture_state:-}" ] && rm -rf "$doctor_fixture_state"
  return 0
}

run_hook_fixture() {
  fixture=$1
  fixture_state=$2
  fixture_turns=$3

  output_json=$(mktemp "${TMPDIR:-/tmp}/cuerail-doctor-hook-output.XXXXXX.json")
  stderr_log=$(mktemp "${TMPDIR:-/tmp}/cuerail-doctor-hook-stderr.XXXXXX.log")

  if ! CODEX_HOME="$CUERAIL_HOME" CODEX_STATE="$fixture_state" CUERAIL_HOME="$CUERAIL_HOME" CUERAIL_STATE="$fixture_state" CUERAIL_TURNS="$fixture_turns" "$CUERAIL_HOME/bin/cuerail-hook" <"$fixture" >"$output_json" 2>"$stderr_log"; then
    die "fixture hook run failed: $(basename "$fixture")"
  fi

  jq -e . "$output_json" >/dev/null

  if [ -n "$(sed -n '/cuerail-hook: using fallback for /p' "$stderr_log")" ]; then
    die "fixture used fallback: $(basename "$fixture")"
  fi

  rm -f "$output_json" "$stderr_log"
  output_json=
  stderr_log=
}

validate_manifest_schema() {
  manifest=$1

  (
    cd "$CUERAIL_HOME"
    cue vet -c=false ./cue/runtime "$manifest" -d '#HookManifest'
  ) || die "schema_invalid_manifest: $(basename "$manifest")"
}

assert_manifest_content() {
  manifest=$1
  expected_event=$2
  expected_tool=$3

  manifest_json=$(mktemp "${TMPDIR:-/tmp}/cuerail-doctor-manifest.XXXXXX.json")
  (
    cd "$CUERAIL_HOME"
    cue vet -c=false ./cue/runtime "$manifest" -d '#HookManifest' &&
      cue export "$manifest" >"$manifest_json"
  ) || die "schema_invalid_manifest: $(basename "$manifest")"

  if [ -n "$expected_tool" ]; then
    jq -e --arg event "$expected_event" --arg tool "$expected_tool" \
      '.input.hook_event_name == $event and .input.tool_name == $tool and .capture.persist == true' \
      "$manifest_json" >/dev/null ||
      die "wrong_manifest_content: $(basename "$manifest")"
  else
    jq -e --arg event "$expected_event" \
      '.input.hook_event_name == $event and .capture.persist == true' \
      "$manifest_json" >/dev/null ||
      die "wrong_manifest_content: $(basename "$manifest")"
  fi

  rm -f "$manifest_json"
  manifest_json=
}

write_git_status_payload() {
  out=$1

  changed_json=$(git -C "$CUERAIL_HOME" status --porcelain --untracked-files=no |
    sed 's/^...//' |
    jq -R -s 'split("\n") | map(select(length > 0))')
  untracked_json=$(git -C "$CUERAIL_HOME" ls-files --others --exclude-standard |
    jq -R -s 'split("\n") | map(select(length > 0))')
  if [ -n "$(git -C "$CUERAIL_HOME" status --porcelain)" ]; then
    clean=false
  else
    clean=true
  fi

  jq -n \
    --arg head "$(git -C "$CUERAIL_HOME" rev-parse --short HEAD)" \
    --arg branch "$(git -C "$CUERAIL_HOME" rev-parse --abbrev-ref HEAD)" \
    --argjson clean "$clean" \
    --argjson changed "$changed_json" \
    --argjson untracked "$untracked_json" \
    '{
      head: $head,
      branch: $branch,
      clean: $clean,
      changed: $changed,
      untracked: $untracked
    }' >"$out"
}

write_git_diff_payload() {
  scope=$1
  out=$2
  patch_file=$(mktemp "${TMPDIR:-/tmp}/cuerail-doctor-git-patch.XXXXXX")
  paths_file=$(mktemp "${TMPDIR:-/tmp}/cuerail-doctor-git-paths.XXXXXX")
  stat_file=$(mktemp "${TMPDIR:-/tmp}/cuerail-doctor-git-stat.XXXXXX")

  case "$scope" in
    unstaged)
      git -C "$CUERAIL_HOME" diff --no-ext-diff --binary >"$patch_file"
      git -C "$CUERAIL_HOME" diff --name-only >"$paths_file"
      git -C "$CUERAIL_HOME" diff --numstat >"$stat_file"
      ;;
    staged)
      git -C "$CUERAIL_HOME" diff --cached --no-ext-diff --binary >"$patch_file"
      git -C "$CUERAIL_HOME" diff --cached --name-only >"$paths_file"
      git -C "$CUERAIL_HOME" diff --cached --numstat >"$stat_file"
      ;;
    *)
      die "invalid git diff payload scope: $scope"
      ;;
  esac

  paths_json=$(jq -R -s 'split("\n") | map(select(length > 0))' "$paths_file")
  stat_json=$(awk -F '\t' '
    BEGIN { files = 0; insertions = 0; deletions = 0 }
    NF >= 3 {
      files += 1
      if ($1 ~ /^[0-9]+$/) insertions += $1
      if ($2 ~ /^[0-9]+$/) deletions += $2
    }
    END {
      printf "{\"files\":%d,\"insertions\":%d,\"deletions\":%d}", files, insertions, deletions
    }
  ' "$stat_file")

  jq -n \
    --arg scope "$scope" \
    --rawfile patch "$patch_file" \
    --argjson stat "$stat_json" \
    --argjson paths "$paths_json" \
    '{
      scope: $scope,
      patch: $patch,
      stat: $stat,
      paths: $paths
    }' >"$out"

  rm -f "$patch_file" "$paths_file" "$stat_file"
}

mode=${1:-source}
[ "$#" -le 1 ] || die "usage: cuerail-doctor [source|runtime|all]"

case "$mode" in
  source|runtime|all) ;;
  *) die "usage: cuerail-doctor [source|runtime|all]" ;;
esac

if [ "$mode" = "runtime" ]; then
  run_runtime_checks
  printf 'cuerail-doctor: runtime ok\n'
  exit 0
fi

CUERAIL_HOME="${CUERAIL_HOME:-$(resolve_source_home)}"

[ -d "$CUERAIL_HOME" ] || die "missing CUERAIL_HOME: $CUERAIL_HOME"
[ ! -L "$CUERAIL_HOME" ] || die "CUERAIL_HOME must not be a symlink"
[ -x "$CUERAIL_HOME/bin/cuerail-hook" ] || die "missing executable bin/cuerail-hook"
[ -x "$CUERAIL_HOME/bin/cuerail-doctor" ] || die "missing executable bin/cuerail-doctor"
[ -x "$CUERAIL_HOME/bin/cuerail-review-packet" ] || die "missing executable bin/cuerail-review-packet"
[ -x "$CUERAIL_HOME/bin/cuerail-schema-sync" ] || die "missing executable bin/cuerail-schema-sync"
[ -x "$CUERAIL_HOME/bin/cuerail-config-schema-sync" ] || die "missing executable bin/cuerail-config-schema-sync"
[ -x "$CUERAIL_HOME/bin/cuerail-token-usage" ] || die "missing executable bin/cuerail-token-usage"
[ -x "$CUERAIL_HOME/bin/cuerail-run" ] || die "missing executable bin/cuerail-run"
[ -x "$CUERAIL_HOME/bin/cuerail-adapter-export" ] || die "missing executable bin/cuerail-adapter-export"
[ -x "$CUERAIL_HOME/bin/cuerail-mcp-ripgrep" ] || die "missing executable bin/cuerail-mcp-ripgrep"
[ -x "$CUERAIL_HOME/bin/cuerail-mcp-capture" ] || die "missing executable bin/cuerail-mcp-capture"
[ -x "$CUERAIL_HOME/bin/cuerail-git-mcp-go" ] || die "missing executable bin/cuerail-git-mcp-go"
[ -x "$CUERAIL_HOME/bin/cuerail-git-capture" ] || die "missing executable bin/cuerail-git-capture"
[ -x "$CUERAIL_HOME/bin/cuerail-rg-capture" ] || die "missing executable bin/cuerail-rg-capture"
[ -x "$CUERAIL_HOME/bin/git-mcp-go-cuerail" ] || die "missing executable bin/git-mcp-go-cuerail"
[ -d "$CUERAIL_HOME/cue" ] || die "missing active CUE package"

need cue
need cmp
need find
need jq
need mktemp
need flock
need mkdir
need mv
need rm
