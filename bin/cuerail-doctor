  (
    cd "$CUERAIL_HOME"
    cue vet -c=false ./cue/runtime "$token_usage_json" -d '#TokenUsageEvidence'
  ) || die "schema_invalid_token_usage_evidence: $(basename "$fixture")"

  rm -f "$token_usage_json"
