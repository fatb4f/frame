  --adapter mcp --from-json "$git_staged_payload_json" --repo "$CUERAIL_HOME" --repo-name cuerail diff-staged >>"$generated_git_capture_paths"
git_green_count=0
while IFS= read -r evidence; do
  [ -f "$evidence" ] || die "generated git evidence missing: $evidence"
  (
    cd "$CUERAIL_HOME"
    cue vet -c=false ./cue/runtime "$evidence" -d '#GitRepoCapture'
  ) || die "schema_invalid_generated_git_capture: $(basename "$evidence")"
  jq -e '
    .adapter == "git-mcp-go" and
    .readiness == "green" and
    .source.tool == "git-mcp-go" and
    (.evidence.cacheRel | startswith("mcp/git-mcp-go/evidence/repos/cuerail/"))
  ' "$evidence" >/dev/null ||
    die "generated git MCP evidence not explicitly green: $evidence"
  git_green_count=$((git_green_count + 1))
done <"$generated_git_capture_paths"
[ "$git_green_count" -eq 3 ] ||
  die "wrong generated git MCP evidence count: $git_green_count"
rm -f "$generated_git_capture_paths" "$git_status_payload_json" "$git_unstaged_payload_json" "$git_staged_payload_json"
