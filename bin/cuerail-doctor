  .readSources.git.state == "green" and
  (.readSources.git.files | length) == 3 and
  all(.readSources.git.files[]; .adapter == "git-mcp-go" and .readiness == "green") and
  .readSources.rg.state == "green" and
  (.readSources.rg.files | length) == 1 and
  all(.readSources.rg.files[]; .adapter == "mcp-ripgrep" and .readiness == "green") and
  .hookFrames.sessionStart.phase == "session_start" and
  .hookFrames.sessionStart.status.projectionValidity == "green" and
  any(.hookFrames.sessionStart.status.sources[]; .kind == "mcp" and .tool == "git-mcp-go" and .readOnly == true) and
  .hookFrames.preToolUse.phase == "pre_tool_use" and
  .hookFrames.preToolUse.status.projectionValidity == "green" and
  any(.hookFrames.preToolUse.status.sources[]; .kind == "mcp" and .tool == "mcp-ripgrep" and .readOnly == true) and
  .hookFrames.postToolUse.phase == "post_tool_use" and
  .hookFrames.postToolUse.status.projectionValidity == "green" and
  .hookFrames.stop.phase == "stop" and
  .hookFrames.stop.status.projectionValidity == "green"
' "$review_packet_json" >/dev/null ||
  die "review packet did not project fallback read sources into hook frames"
