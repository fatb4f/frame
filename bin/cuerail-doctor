output_json=$(mktemp "${TMPDIR:-/tmp}/cuerail-doctor-agent-feed.XXXXXX.json")
jq -n '{
  hookInput: {
    cwd: "/tmp/cuerail-example",
    hook_event_name: "SessionStart",
    model: "gpt-4.1",
    permission_mode: "default",
    session_id: "session-example",
    source: "startup",
    transcript_path: null,
  },
  awarenessResults: [],
  awarenessExecutable: false,
  awarenessExecutionReason: "no_mcp_read_executor",
  agentFeedbackContext: "Cuerail raw hook feedback:\n{\"schemaVersion\":\"cuerail.agentFeedback.raw.v1\",\"hookEventName\":\"SessionStart\",\"sessionId\":\"session-example\",\"input\":{\"hook_event_name\":\"SessionStart\"},\"awareness\":{\"executable\":false,\"reason\":\"no_mcp_read_executor\",\"plan\":{\"phase\":\"SessionStart\",\"ops\":[]},\"results\":[]}}",
  agentFeedbackMaxBytes: 8000,
  agentFeedbackTruncated: false,
  agentFeedbackSource: "hook.raw"
}' >"$output_json"
(
  cd "$CUERAIL_HOME"
  cue export ./cue/runtime "$output_json" -e '#HookManifest' |
    jq -e '
      .agentFeed.enabled == true and
      .agentFeed.channel == "stdout.additionalContext" and
      .agentFeed.status == "emitted" and
      .agentFeed.payloadKind == "raw.event" and
      .agentFeed.bytes > 0 and
      .agentFeed.maxBytes == 8000 and
      (.agentFeed.truncated | type) == "boolean" and
      .agentFeed.source == "hook.raw" and
      .output.hookSpecificOutput.hookEventName == "SessionStart" and
      (.output.hookSpecificOutput.additionalContext | contains("cuerail.agentFeedback.raw.v1")) and
      (.output.hookSpecificOutput.additionalContext | contains("\"executable\":false")) and
      (.output.hookSpecificOutput.additionalContext | contains("no_mcp_read_executor")) and
      (.output.hookSpecificOutput.additionalContext | length) == .agentFeed.bytes and
      (.output.hookSpecificOutput.additionalContext | length) <= .agentFeed.maxBytes
    ' >/dev/null
) || die "agent_feed_session_start_projection_invalid"
rm -f "$output_json"
output_json=

output_json=$(mktemp "${TMPDIR:-/tmp}/cuerail-doctor-agent-feed.XXXXXX.json")
jq -n '{
  hookInput: {
    cwd: "/tmp/cuerail-example",
