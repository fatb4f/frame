#!/usr/bin/env sh
set -eu

die() {
  printf 'cuerail-hook: %s\n' "$1" >&2
  exit 1
}

cleanup_temp_files() {
  [ -n "${input_json:-}" ] && rm -f "$input_json"
  [ -n "${wrapped_json:-}" ] && rm -f "$wrapped_json"
  [ -n "${wrapped_with_results_json:-}" ] && rm -f "$wrapped_with_results_json"
  [ -n "${plan_json:-}" ] && rm -f "$plan_json"
  [ -n "${results_json:-}" ] && rm -f "$results_json"
  [ -n "${output_json:-}" ] && rm -f "$output_json"
  [ -n "${persist_json:-}" ] && rm -f "$persist_json"
  [ -n "${file_stem_json:-}" ] && rm -f "$file_stem_json"
  [ -n "${manifest_cue:-}" ] && rm -f "$manifest_cue"
  return 0
}

safe_component() {
  printf '%s' "$1" | tr -c 'A-Za-z0-9._-' '_'
}

execute_awareness_plan() {
  plan=$1
  results=$2
  tmp_results=$(mktemp "${TMPDIR:-/tmp}/cuerail-hook-results.XXXXXX.json")
  printf '[]\n' >"$tmp_results"

  jq -c '.ops[]?' "$plan" | while IFS= read -r op_json; do
    op_file=$(mktemp "${TMPDIR:-/tmp}/cuerail-hook-op.XXXXXX.json")
    raw_file=$(mktemp "${TMPDIR:-/tmp}/cuerail-hook-raw.XXXXXX.json")
    err_file=$(mktemp "${TMPDIR:-/tmp}/cuerail-hook-error.XXXXXX.txt")
    env_file=$(mktemp "${TMPDIR:-/tmp}/cuerail-hook-envelope.XXXXXX.json")
    printf '%s\n' "$op_json" >"$op_file"

    if [ -n "${CUERAIL_MCP_READ_EXECUTOR:-}" ]; then
      if "$CUERAIL_MCP_READ_EXECUTOR" "$op_file" >"$raw_file" 2>"$err_file"; then
        if jq -e . "$raw_file" >/dev/null 2>&1; then
          jq -n --slurpfile op "$op_file" --slurpfile raw "$raw_file" '
            if ($raw | length) == 1 then
              {
                id: $op[0].id,
                status: "ok",
                substrate: $op[0].substrate,
                tool: $op[0].tool,
                op: $op[0].op,
                input: $op[0].input,
                raw: $raw[0]
              }
            else
              {
                id: $op[0].id,
                status: "error",
                substrate: $op[0].substrate,
                tool: $op[0].tool,
                op: $op[0].op,
                input: $op[0].input,
                error: "executor stdout must contain exactly one JSON value"
              }
            end' >"$env_file"
        else
          jq -n --slurpfile op "$op_file" --rawfile rawText "$raw_file" '
            {
              id: $op[0].id,
              status: "error",
              substrate: $op[0].substrate,
              tool: $op[0].tool,
              op: $op[0].op,
              input: $op[0].input,
              rawText: $rawText,
              error: "executor stdout was not valid JSON"
            }' >"$env_file"
        fi
      else
        jq -n --slurpfile op "$op_file" --rawfile error "$err_file" '
          {
            id: $op[0].id,
            status: "error",
            substrate: $op[0].substrate,
            tool: $op[0].tool,
            op: $op[0].op,
            input: $op[0].input,
            error: $error
          }' >"$env_file"
      fi
    else
      jq -n --slurpfile op "$op_file" '
        {
          id: $op[0].id,
          status: "error",
          substrate: $op[0].substrate,
          tool: $op[0].tool,
          op: $op[0].op,
          input: $op[0].input,
          error: "no MCP read executor configured"
        }' >"$env_file"
    fi

    jq --slurpfile env "$env_file" '. + [$env[0]]' "$tmp_results" >"$results.tmp"
    mv "$results.tmp" "$tmp_results"
    rm -f "$op_file" "$raw_file" "$err_file" "$env_file"
  done

  mv "$tmp_results" "$results"
}

: "${CODEX_HOME:?CODEX_HOME is required}"
: "${CODEX_STATE:?CODEX_STATE is required}"
: "${CUERAIL_HOME:=$CODEX_HOME/tools/cuerail}"

CUERAIL_STATE="${CUERAIL_STATE:-$CODEX_STATE/cuerail}"
CUERAIL_TURNS="${CUERAIL_TURNS:-$CUERAIL_STATE/turns}"
export CODEX_HOME CODEX_STATE CUERAIL_HOME CUERAIL_STATE CUERAIL_TURNS

command -v jq >/dev/null 2>&1 || die "missing required command: jq"
command -v cue >/dev/null 2>&1 || die "missing required command: cue"
command -v flock >/dev/null 2>&1 || die "missing required command: flock"
command -v mkdir >/dev/null 2>&1 || die "missing required command: mkdir"
command -v mktemp >/dev/null 2>&1 || die "missing required command: mktemp"
command -v mv >/dev/null 2>&1 || die "missing required command: mv"
command -v rm >/dev/null 2>&1 || die "missing required command: rm"
command -v sed >/dev/null 2>&1 || die "missing required command: sed"
command -v tr >/dev/null 2>&1 || die "missing required command: tr"

input_json=$(mktemp "${TMPDIR:-/tmp}/cuerail-hook.XXXXXX.json")
wrapped_json=$(mktemp "${TMPDIR:-/tmp}/cuerail-hook-wrapped.XXXXXX.json")
wrapped_with_results_json=$(mktemp "${TMPDIR:-/tmp}/cuerail-hook-wrapped-results.XXXXXX.json")
plan_json=$(mktemp "${TMPDIR:-/tmp}/cuerail-hook-plan.XXXXXX.json")
results_json=$(mktemp "${TMPDIR:-/tmp}/cuerail-hook-results.XXXXXX.json")
output_json=$(mktemp "${TMPDIR:-/tmp}/cuerail-hook-output.XXXXXX.json")
persist_json=$(mktemp "${TMPDIR:-/tmp}/cuerail-hook-persist.XXXXXX.json")
file_stem_json=$(mktemp "${TMPDIR:-/tmp}/cuerail-hook-file-stem.XXXXXX.json")
manifest_cue=
trap cleanup_temp_files EXIT HUP INT TERM

cat >"$input_json"

event_name=$(jq -r '.hook_event_name // empty' "$input_json") || die "invalid hook JSON"
tool_name=$(jq -r '.tool_name // empty' "$input_json") || die "invalid hook JSON"

jq -c '{hookInput: .}' "$input_json" >"$wrapped_json" || die "could not wrap hook JSON"

if (
  cd "$CUERAIL_HOME" &&
  cue export ./cue/runtime "$wrapped_json" -e '#HookManifest.awareness.plan' >"$plan_json"
); then
  execute_awareness_plan "$plan_json" "$results_json"
  jq -c --slurpfile results "$results_json" '. + {awarenessResults: $results[0]}' \
    "$wrapped_json" >"$wrapped_with_results_json" || die "could not inject awareness results"

  (
    cd "$CUERAIL_HOME" &&
    cue export ./cue/runtime "$wrapped_with_results_json" -e '#HookManifest.output' >"$output_json" &&
    cue export ./cue/runtime "$wrapped_with_results_json" -e '#HookManifest.capture.persist' >"$persist_json" &&
    cue export ./cue/runtime "$wrapped_with_results_json" -e '#HookManifest.capture.fileStem' >"$file_stem_json"
  ) || die "could not export hook output"

  persist=$(jq -r 'if . == true then "true" else "false" end' "$persist_json") ||
    die "invalid capture persist output"

  if [ "$persist" = "true" ]; then
    session_id=$(jq -r '.session_id // empty' "$input_json") || die "invalid hook JSON"
    turn_id=$(jq -r '.turn_id // "session-start"' "$input_json") || die "invalid hook JSON"

    [ -n "$session_id" ] || die "persisted hook missing session_id"
    [ -n "$turn_id" ] || die "persisted hook missing turn_id"

    safe_session=$(safe_component "$session_id")
    safe_turn=$(safe_component "$turn_id")
    slug=$(jq -r '. // empty' "$file_stem_json") || die "invalid capture fileStem output"
    [ -n "$slug" ] || die "persisted hook missing capture fileStem"
    slug=$(safe_component "$slug")
    turn_dir="$CUERAIL_TURNS/$safe_session/$safe_turn"
    events_dir="$turn_dir/events"

    mkdir -p "$events_dir" || die "could not create turn events directory"

    (
      flock -x 9 || die "could not lock turn directory"

      next_seq=1
      for existing_event in "$events_dir"/[0-9][0-9][0-9][0-9][0-9][0-9]-*.cue; do
        [ -e "$existing_event" ] || continue
        base_name=${existing_event##*/}
        seq_text=${base_name%%-*}
        seq_value=$(printf '%s' "$seq_text" | sed 's/^0*//')
        [ -n "$seq_value" ] || seq_value=0
        [ "$seq_value" -lt "$next_seq" ] || next_seq=$((seq_value + 1))
      done

      seq_name=$(printf '%06d' "$next_seq")
      manifest_cue=$(mktemp "$events_dir/.tmp.XXXXXX.cue") ||
        die "could not create temporary manifest"

      (
        cd "$CUERAIL_HOME" &&
        cue export ./cue/runtime "$wrapped_with_results_json" -e '#HookManifest' --out cue >"$manifest_cue" &&
        cue vet -c=false ./cue/runtime "$manifest_cue" -d '#HookManifest'
      ) || die "could not export or validate hook manifest"

      mv "$manifest_cue" "$events_dir/$seq_name-$slug.cue" ||
        die "could not publish hook manifest"
      manifest_cue=
    ) 9>"$turn_dir/.lock"
  fi

  cat "$output_json"
  exit 0
fi

fallback_output() {
  printf 'cuerail-hook: using fallback for %s\n' "$event_name" >&2
  case "$1" in
    SessionStart|UserPromptSubmit|PostToolUse|PreCompact|PostCompact|SubagentStart)
      printf '{}\n'
      ;;
    PreToolUse|Stop|SubagentStop)
      printf '{"decision":"block","reason":"cuerail fallback"}\n'
      ;;
    PermissionRequest)
      printf '%s\n' '{"hookSpecificOutput":{"hookEventName":"PermissionRequest","decision":{"behavior":"deny"}}}'
      ;;
    "")
      die "missing hook_event_name"
      ;;
    *)
      die "unsupported placeholder hook event: $event_name"
      ;;
  esac
}

fallback_output "$event_name"
