#!/usr/bin/env sh
set -eu

die() {
  printf 'cuerail-hook: %s\n' "$1" >&2
  exit 1
}

cleanup_temp_files() {
  [ -n "${input_json:-}" ] && rm -f "$input_json"
  [ -n "${wrapped_json:-}" ] && rm -f "$wrapped_json"
  [ -n "${wrapped_with_results_json:-}" ] && rm -f "$wrapped_with_results_json"
  [ -n "${plan_json:-}" ] && rm -f "$plan_json"
  [ -n "${results_json:-}" ] && rm -f "$results_json"
  [ -n "${awareness_meta_json:-}" ] && rm -f "$awareness_meta_json"
  [ -n "${agent_feedback_json:-}" ] && rm -f "$agent_feedback_json"
  [ -n "${output_json:-}" ] && rm -f "$output_json"
  [ -n "${persist_json:-}" ] && rm -f "$persist_json"
  [ -n "${file_stem_json:-}" ] && rm -f "$file_stem_json"
  [ -n "${manifest_cue:-}" ] && rm -f "$manifest_cue"
  return 0
}

safe_component() {
  printf '%s' "$1" | tr -c 'A-Za-z0-9._-' '_'
}

execute_awareness_plan() {
  plan=$1
  results=$2
  meta=$3
  tmp_results=$(mktemp "${TMPDIR:-/tmp}/cuerail-hook-results.XXXXXX.json")
  printf '[]\n' >"$tmp_results"

  op_count=$(jq '.ops | length' "$plan") || die "invalid awareness plan"
  if [ "$op_count" -gt 0 ] && [ -z "${CUERAIL_MCP_READ_EXECUTOR:-}" ]; then
    jq -n '{awarenessExecutable: false, reason: "no_mcp_read_executor"}' >"$meta"
    mv "$tmp_results" "$results"
    return 0
  fi

  jq -n '{awarenessExecutable: true}' >"$meta"

  jq -c '.ops[]?' "$plan" | while IFS= read -r op_json; do
    op_file=$(mktemp "${TMPDIR:-/tmp}/cuerail-hook-op.XXXXXX.json")
    raw_file=$(mktemp "${TMPDIR:-/tmp}/cuerail-hook-raw.XXXXXX.json")
    err_file=$(mktemp "${TMPDIR:-/tmp}/cuerail-hook-error.XXXXXX.txt")
    env_file=$(mktemp "${TMPDIR:-/tmp}/cuerail-hook-envelope.XXXXXX.json")
    printf '%s\n' "$op_json" >"$op_file"

    if [ -n "${CUERAIL_MCP_READ_EXECUTOR:-}" ]; then
      if "$CUERAIL_MCP_READ_EXECUTOR" "$op_file" >"$raw_file" 2>"$err_file"; then
        if jq -e . "$raw_file" >/dev/null 2>&1; then
          jq -n --slurpfile op "$op_file" --slurpfile raw "$raw_file" '
            if ($raw | length) == 1 then
              $raw[0]
            else
              {
                id: $op[0].id,
                status: "error",
                substrate: $op[0].substrate,
                tool: $op[0].tool,
                op: $op[0].op,
                input: $op[0].input,
                error: "executor stdout must contain exactly one JSON value"
              }
            end' >"$env_file"
        else
          jq -n --slurpfile op "$op_file" --rawfile rawText "$raw_file" '
            {
              id: $op[0].id,
              status: "error",
              substrate: $op[0].substrate,
              tool: $op[0].tool,
              op: $op[0].op,
              input: $op[0].input,
              rawText: $rawText,
              error: "executor stdout was not valid JSON"
            }' >"$env_file"
        fi
      else
        jq -n --slurpfile op "$op_file" --rawfile error "$err_file" '
          {
            id: $op[0].id,
            status: "error",
            substrate: $op[0].substrate,
            tool: $op[0].tool,
            op: $op[0].op,
            input: $op[0].input,
            error: $error
          }' >"$env_file"
      fi
    fi

    jq --slurpfile env "$env_file" '. + [$env[0]]' "$tmp_results" >"$results.tmp"
    mv "$results.tmp" "$tmp_results"
    rm -f "$op_file" "$raw_file" "$err_file" "$env_file"
  done

  mv "$tmp_results" "$results"
}

: "${CODEX_HOME:?CODEX_HOME is required}"
: "${CODEX_STATE:?CODEX_STATE is required}"
: "${CUERAIL_HOME:=$CODEX_HOME/tools/cuerail}"

CUERAIL_STATE="${CUERAIL_STATE:-$CODEX_STATE/cuerail}"
CUERAIL_TURNS="${CUERAIL_TURNS:-$CUERAIL_HOME/.cuerail/runs}"
export CODEX_HOME CODEX_STATE CUERAIL_HOME CUERAIL_STATE CUERAIL_TURNS

command -v jq >/dev/null 2>&1 || die "missing required command: jq"
command -v cue >/dev/null 2>&1 || die "missing required command: cue"
command -v flock >/dev/null 2>&1 || die "missing required command: flock"
command -v mkdir >/dev/null 2>&1 || die "missing required command: mkdir"
command -v mktemp >/dev/null 2>&1 || die "missing required command: mktemp"
command -v mv >/dev/null 2>&1 || die "missing required command: mv"
command -v rm >/dev/null 2>&1 || die "missing required command: rm"
command -v sed >/dev/null 2>&1 || die "missing required command: sed"
command -v tr >/dev/null 2>&1 || die "missing required command: tr"

input_json=$(mktemp "${TMPDIR:-/tmp}/cuerail-hook.XXXXXX.json")
wrapped_json=$(mktemp "${TMPDIR:-/tmp}/cuerail-hook-wrapped.XXXXXX.json")
wrapped_with_results_json=$(mktemp "${TMPDIR:-/tmp}/cuerail-hook-wrapped-results.XXXXXX.json")
plan_json=$(mktemp "${TMPDIR:-/tmp}/cuerail-hook-plan.XXXXXX.json")
results_json=$(mktemp "${TMPDIR:-/tmp}/cuerail-hook-results.XXXXXX.json")
awareness_meta_json=$(mktemp "${TMPDIR:-/tmp}/cuerail-hook-awareness-meta.XXXXXX.json")
agent_feedback_json=$(mktemp "${TMPDIR:-/tmp}/cuerail-hook-agent-feedback.XXXXXX.json")
output_json=$(mktemp "${TMPDIR:-/tmp}/cuerail-hook-output.XXXXXX.json")
persist_json=$(mktemp "${TMPDIR:-/tmp}/cuerail-hook-persist.XXXXXX.json")
file_stem_json=$(mktemp "${TMPDIR:-/tmp}/cuerail-hook-file-stem.XXXXXX.json")
manifest_cue=
trap cleanup_temp_files EXIT HUP INT TERM

cat >"$input_json"

event_name=$(jq -r '.hook_event_name // empty' "$input_json") || die "invalid hook JSON"
tool_name=$(jq -r '.tool_name // empty' "$input_json") || die "invalid hook JSON"

jq -c '{hookInput: .}' "$input_json" >"$wrapped_json" || die "could not wrap hook JSON"

if (
  cd "$CUERAIL_HOME" &&
  cue export ./cue/runtime "$wrapped_json" -e '#HookManifest.awareness.plan' >"$plan_json"
); then
  execute_awareness_plan "$plan_json" "$results_json" "$awareness_meta_json"
  jq -c --slurpfile results "$results_json" --slurpfile meta "$awareness_meta_json" --slurpfile plan "$plan_json" \
    '. + {awarenessResults: $results[0], awarenessPlan: $plan[0], awarenessExecutable: $meta[0].awarenessExecutable} +
      (if ($meta[0].reason? // "") != "" then {awarenessExecutionReason: $meta[0].reason} else {} end)' \
    "$wrapped_json" >"$wrapped_with_results_json" || die "could not inject awareness results"

  jq -c --argjson maxBytes "${CUERAIL_AGENT_FEEDBACK_MAX_BYTES:-8000}" '
    def feedable_tool:
      (.hookInput.tool_name? // "") as $tool |
      $tool == "mcp__git_mcp_server__git_status" or
      $tool == "mcp__git_mcp_server__git_diff" or
      $tool == "mcp__git_mcp_server__git_diff_staged" or
      $tool == "mcp__git_mcp_server__git_log" or
      $tool == "mcp__mcp_ripgrep__search" or
      $tool == "mcp__mcp_ripgrep__list_files";
    def feed_kind:
      if ((.hookInput.tool_name? // "") | startswith("mcp__git_mcp_server__")) then "compact.mcp.git"
      elif ((.hookInput.tool_name? // "") | startswith("mcp__mcp_ripgrep__")) then "compact.mcp.rg"
      else "compact.hook"
      end;
    def feedable:
      .hookInput.hook_event_name == "SessionStart" or
      (.hookInput.hook_event_name == "UserPromptSubmit" and false) or
      ((.hookInput.hook_event_name == "PreToolUse" or .hookInput.hook_event_name == "PostToolUse") and feedable_tool);
    def feed_decision:
      {
        feedable: feedable,
        reason: (if (feedable and feedable_tool) then "feedable_mcp" elif ((.hookInput.hook_event_name == "PreToolUse" or .hookInput.hook_event_name == "PostToolUse") and (feedable_tool | not)) then "tool_not_feedable" else "persist_only_phase" end)
      } + (if (.hookInput.tool_name? // "") != "" then {toolName: .hookInput.tool_name} else {} end);
    def compact_awareness:
      {
        executable: (if has("awarenessExecutable") then .awarenessExecutable else true end),
        plan: (.awarenessPlan // null),
        results: (.awarenessResults // [])
      } + (if (.awarenessExecutionReason? // "") != "" then {reason: .awarenessExecutionReason} else {} end);
    def response_text:
      if (.hookInput | has("tool_response") | not) then ""
      elif (.hookInput.tool_response | type) == "string" then .hookInput.tool_response
      elif ((.hookInput.tool_response.content? // null) | type) == "array" then
        [.hookInput.tool_response.content[]? | select((.type? // "") == "text") | .text? // ""] | join("\n")
      else (.hookInput.tool_response | tostring)
      end;
    def response_summary:
      response_text as $text |
      ($text | split("\n") | map(select(length > 0))) as $lines |
      {
        kind: (if (.hookInput | has("tool_response")) then (.hookInput.tool_response | type) else "none" end),
        bytes: ($text | length),
        truncated: (($text | length) > 2000),
        preview: $text[0:2000]
      } +
      (if .hookInput.tool_name == "mcp__mcp_ripgrep__search" then {
        summary: {
          kind: "rg.search",
          path: .hookInput.tool_input.path,
          pattern: .hookInput.tool_input.pattern,
          maxResults: (.hookInput.tool_input.maxResults? // null),
          resultCount: (if ($text | test("^No matches found"; "m")) then 0 else ($lines | length) end),
          previewMatches: ($lines[0:20])
        }
      } elif .hookInput.tool_name == "mcp__mcp_ripgrep__list_files" then {
        summary: {
          kind: "rg.list_files",
          rootPath: .hookInput.tool_input.path,
          filePattern: (.hookInput.tool_input.filePattern? // null),
          includeHidden: (.hookInput.tool_input.includeHidden? // null),
          fileCount: ($lines | length),
          previewPaths: ($lines[0:40])
        }
      } elif .hookInput.tool_name == "mcp__git_mcp_server__git_status" then {
        summary: {
          kind: "git.status",
          branch: (($text | capture("On branch (?<branch>[^\\n]+)")? // {}).branch // null),
          clean: ($text | contains("working tree clean")),
          changed: (($text | contains("Changes not staged")) or ($text | contains("Changes to be committed"))),
          untracked: ($text | contains("Untracked files")),
          head: null
        }
      } elif (.hookInput.tool_name == "mcp__git_mcp_server__git_diff" or .hookInput.tool_name == "mcp__git_mcp_server__git_diff_staged") then {
        summary: {
          kind: "git.diff",
          scope: (if .hookInput.tool_name == "mcp__git_mcp_server__git_diff_staged" then "staged" else "working" end),
          stat: ($lines | map(select(test("^ [^|]+\\|") or test(" files? changed"))) | .[0:20]),
          paths: ($lines | map(select(test("^diff --git ")) | sub("^diff --git a/"; "") | sub(" b/.*$"; "")) | .[0:40])
        }
      } elif .hookInput.tool_name == "mcp__git_mcp_server__git_log" then {
        summary: {
          kind: "git.log",
          entries: ($lines[0:20])
        }
      } else {} end);
    def compact_tool_pre:
      {} +
      (if (.hookInput.tool_name? // "") != "" then {name: .hookInput.tool_name} else {} end) +
      (if .hookInput | has("tool_input") then {input: .hookInput.tool_input} else {} end);
    def compact_tool_post:
      compact_tool_pre +
      (if (.hookInput.tool_use_id? // "") != "" then {useId: .hookInput.tool_use_id} else {} end) +
      {response: response_summary};
    def evidence_pointer:
      {
        sessionId: .hookInput.session_id,
        turnId: (.hookInput.turn_id? // null),
        toolUseId: (.hookInput.tool_use_id? // null),
        persistedEventPath: null
      };
    def compact_event:
      if .hookInput.hook_event_name == "SessionStart" then {
        schemaVersion: "cuerail.agentFeedback.compact.v1",
        hookEventName: .hookInput.hook_event_name,
        sessionId: .hookInput.session_id,
        input: {
          hook_event_name: .hookInput.hook_event_name,
          cwd: (.hookInput.cwd? // null),
          model: (.hookInput.model? // null),
          permission_mode: (.hookInput.permission_mode? // null),
          source: (.hookInput.source? // null)
        },
        awareness: compact_awareness,
        agentFeed: feed_decision,
        evidence: evidence_pointer
      }
      elif .hookInput.hook_event_name == "PreToolUse" then {
        schemaVersion: "cuerail.agentFeedback.compact.v1",
        hookEventName: .hookInput.hook_event_name,
        sessionId: .hookInput.session_id,
        tool: compact_tool_pre,
        awareness: compact_awareness,
        agentFeed: feed_decision,
        evidence: evidence_pointer
      } + (if (.hookInput.turn_id? // "") != "" then {turnId: .hookInput.turn_id} else {} end)
      elif .hookInput.hook_event_name == "PostToolUse" then {
        schemaVersion: "cuerail.agentFeedback.compact.v1",
        hookEventName: .hookInput.hook_event_name,
        sessionId: .hookInput.session_id,
        tool: compact_tool_post,
        awareness: compact_awareness,
        agentFeed: feed_decision,
        evidence: evidence_pointer
      } + (if (.hookInput.turn_id? // "") != "" then {turnId: .hookInput.turn_id} else {} end)
      else empty
      end;
    if feedable then
      ("Cuerail compact hook feedback:\n" + (compact_event | tojson)) as $fullContext |
      . + {
        agentFeedbackContext: ($fullContext[0:$maxBytes]),
        agentFeedbackMaxBytes: $maxBytes,
        agentFeedbackTruncated: (($fullContext | length) > $maxBytes),
        agentFeedbackSource: "hook.compact",
        agentFeedbackPayloadKind: feed_kind,
        agentFeedbackReason: feed_decision.reason
      }
    else
      . + {
        agentFeedbackPayloadKind: "none",
        agentFeedbackReason: feed_decision.reason
      }
    end' "$wrapped_with_results_json" >"$agent_feedback_json" ||
    die "could not build agent feedback context"
  mv "$agent_feedback_json" "$wrapped_with_results_json" ||
    die "could not inject agent feedback context"

  (
    cd "$CUERAIL_HOME" &&
    cue export ./cue/runtime "$wrapped_with_results_json" -e '#HookManifest.output' >"$output_json" &&
    cue export ./cue/runtime "$wrapped_with_results_json" -e '#HookManifest.capture.persist' >"$persist_json" &&
    cue export ./cue/runtime "$wrapped_with_results_json" -e '#HookManifest.capture.fileStem' >"$file_stem_json"
  ) || die "could not export hook output"

  persist=$(jq -r 'if . == true then "true" else "false" end' "$persist_json") ||
    die "invalid capture persist output"

  if [ "$persist" = "true" ]; then
    session_id=$(jq -r '.session_id // empty' "$input_json") || die "invalid hook JSON"
    turn_id=$(jq -r '.turn_id // "session-start"' "$input_json") || die "invalid hook JSON"

    [ -n "$session_id" ] || die "persisted hook missing session_id"
    [ -n "$turn_id" ] || die "persisted hook missing turn_id"

    safe_session=$(safe_component "$session_id")
    safe_turn=$(safe_component "$turn_id")
    slug=$(jq -r '. // empty' "$file_stem_json") || die "invalid capture fileStem output"
    [ -n "$slug" ] || die "persisted hook missing capture fileStem"
    slug=$(safe_component "$slug")
    turn_dir="$CUERAIL_TURNS/$safe_session/$safe_turn"
    events_dir="$turn_dir/events"

    mkdir -p "$events_dir" || die "could not create turn events directory"

    (
      flock -x 9 || die "could not lock turn directory"

      next_seq=1
      for existing_event in "$events_dir"/[0-9][0-9][0-9][0-9][0-9][0-9]-*.cue; do
        [ -e "$existing_event" ] || continue
        base_name=${existing_event##*/}
        seq_text=${base_name%%-*}
        seq_value=$(printf '%s' "$seq_text" | sed 's/^0*//')
        [ -n "$seq_value" ] || seq_value=0
        [ "$seq_value" -lt "$next_seq" ] || next_seq=$((seq_value + 1))
      done

      seq_name=$(printf '%06d' "$next_seq")
      manifest_cue=$(mktemp "$events_dir/.tmp.XXXXXX.cue") ||
        die "could not create temporary manifest"

      (
        cd "$CUERAIL_HOME" &&
        cue export ./cue/runtime "$wrapped_with_results_json" -e '#HookManifest' --out cue >"$manifest_cue" &&
        cue vet -c=false ./cue/runtime "$manifest_cue" -d '#HookManifest'
      ) || die "could not export or validate hook manifest"

      mv "$manifest_cue" "$events_dir/$seq_name-$slug.cue" ||
        die "could not publish hook manifest"
      manifest_cue=
    ) 9>"$turn_dir/.lock"
  fi

  cat "$output_json"
  exit 0
fi

fallback_output() {
  printf 'cuerail-hook: using fallback for %s\n' "$event_name" >&2
  case "$1" in
    SessionStart|UserPromptSubmit|PostToolUse|PreCompact|PostCompact|SubagentStart)
      printf '{}\n'
      ;;
    PreToolUse|Stop|SubagentStop)
      printf '{"decision":"block","reason":"cuerail fallback"}\n'
      ;;
    PermissionRequest)
      printf '%s\n' '{"hookSpecificOutput":{"hookEventName":"PermissionRequest","decision":{"behavior":"deny"}}}'
      ;;
    "")
      die "missing hook_event_name"
      ;;
    *)
      die "unsupported placeholder hook event: $event_name"
      ;;
  esac
}

fallback_output "$event_name"
