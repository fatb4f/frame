#!/usr/bin/env node
const fs = require("node:fs");
const { spawn, spawnSync } = require("node:child_process");

const DEFAULT_TIMEOUT_MS = 3000;
const PROTOCOL_VERSION = "2025-06-18";

class TimeoutError extends Error {
  constructor() {
    super("mcp_read_timeout");
    this.name = "TimeoutError";
  }
}

function die(message) {
  process.stderr.write(`cuerail-mcp-read-executor: ${message}\n`);
  process.exit(1);
}

function readInput() {
  if (process.argv.length > 3) die("usage: cuerail-mcp-read-executor [READ_OP_JSON]");
  const text = process.argv[2] ? fs.readFileSync(process.argv[2], "utf8") : fs.readFileSync(0, "utf8");
  try {
    return JSON.parse(text);
  } catch (error) {
    die(`invalid ReadOp JSON: ${error.message}`);
  }
}

function validateReadOp(op) {
  if (typeof op.id !== "string" || op.id.length === 0) die("ReadOp.id is required");
  if (typeof op.phase !== "string" || op.phase.length === 0) die("ReadOp.phase is required");
  if (op.kind !== "git" && op.kind !== "rg") die('ReadOp.kind must be "git" or "rg"');
  if (op.readOnly !== true) die("ReadOp.readOnly must be true");
  if (op.substrate !== "mcp") die('ReadOp.substrate must be "mcp"');
  if (op.tool !== "mcp-ripgrep" && op.tool !== "git-mcp-server") die(`unsupported MCP tool: ${op.tool}`);
  if (op.kind === "git" && op.tool !== "git-mcp-server") die('ReadOp.kind "git" requires tool "git-mcp-server"');
  if (op.kind === "rg" && op.tool !== "mcp-ripgrep") die('ReadOp.kind "rg" requires tool "mcp-ripgrep"');
  if (typeof op.op !== "string" || op.op.length === 0) die("ReadOp.op must be a non-empty MCP tool name");
  if (!Object.prototype.hasOwnProperty.call(op, "input")) die("ReadOp.input is required");
}

function timeoutMs() {
  const text = process.env.CUERAIL_MCP_READ_TIMEOUT_MS || String(DEFAULT_TIMEOUT_MS);
  const value = Number(text);
  if (!Number.isInteger(value) || value <= 0) die(`CUERAIL_MCP_READ_TIMEOUT_MS must be a positive integer: ${text}`);
  return value;
}

function codexMcpConfig(name) {
  const result = spawnSync("codex", ["mcp", "get", name, "--json"], { encoding: "utf8" });
  if (result.status !== 0) die(`missing Codex MCP config for ${name}: ${result.stderr.trim() || result.stdout.trim()}`);
  try {
    return JSON.parse(result.stdout);
  } catch (error) {
    die(`invalid Codex MCP config JSON for ${name}: ${error.message}`);
  }
}

function serverParams(config) {
  const transport = config.transport || {};
  if (transport.type !== "stdio") die(`unsupported MCP transport for ${config.name}: ${transport.type || "missing"}`);
  if (typeof transport.command !== "string" || transport.command.length === 0) die(`missing MCP command for ${config.name}`);
  const env = { ...process.env };
  if (transport.env && typeof transport.env === "object") Object.assign(env, transport.env);
  return {
    command: transport.command,
    args: Array.isArray(transport.args) ? transport.args : [],
    cwd: transport.cwd || undefined,
    env,
  };
}

function resultEnvelope(op, status, extra) {
  return {
    id: op.id,
    status,
    substrate: op.substrate,
    tool: op.tool,
    op: op.op,
    input: op.input,
    ...extra,
  };
}

function callMcp(params, toolName, args, timeout) {
  return new Promise((resolve, reject) => {
    const child = spawn(params.command, params.args, { cwd: params.cwd, env: params.env, stdio: ["pipe", "pipe", "pipe"] });
    let nextId = 1;
    let stdout = "";
    let stderr = "";
    const pending = new Map();
    let settled = false;
    let killTimer;
    const timer = setTimeout(() => {
      finish(new TimeoutError());
    }, timeout);

    function finish(error, value) {
      if (settled) return;
      settled = true;
      clearTimeout(timer);
      clearTimeout(killTimer);
      try {
        child.stdin.end();
      } catch (_) {}
      if (!child.killed) {
        child.kill("SIGTERM");
        killTimer = setTimeout(() => {
          try {
            child.kill("SIGKILL");
          } catch (_) {}
        }, 250);
      }
      error ? reject(error) : resolve(value);
    }

    function send(message) {
      child.stdin.write(`${JSON.stringify(message)}\n`);
    }

    function request(method, paramsValue) {
      const id = nextId++;
      send({ jsonrpc: "2.0", id, method, params: paramsValue });
      return new Promise((resolveRequest, rejectRequest) => pending.set(id, { resolve: resolveRequest, reject: rejectRequest }));
    }

    child.stdout.on("data", (chunk) => {
      stdout += chunk.toString("utf8");
      for (;;) {
        const index = stdout.indexOf("\n");
        if (index < 0) break;
        const line = stdout.slice(0, index).replace(/\r$/, "");
        stdout = stdout.slice(index + 1);
        if (!line.trim()) continue;
        let message;
        try {
          message = JSON.parse(line);
        } catch (_) {
          finish(new Error(`MCP server emitted non-JSON stdout: ${line}`));
          return;
        }
        if (!Object.prototype.hasOwnProperty.call(message, "id")) continue;
        const waiter = pending.get(message.id);
        if (!waiter) continue;
        pending.delete(message.id);
        message.error ? waiter.reject(new Error(JSON.stringify(message.error))) : waiter.resolve(message.result);
      }
    });

    child.stderr.on("data", (chunk) => {
      stderr += chunk.toString("utf8");
    });
    child.on("error", (error) => finish(error));
    child.on("exit", () => {
      clearTimeout(killTimer);
    });
    child.on("exit", (code) => {
      if (!settled && code !== 0) finish(new Error(`MCP server exited ${code}: ${stderr.trim()}`));
    });

    (async () => {
      try {
        await request("initialize", {
          protocolVersion: PROTOCOL_VERSION,
          capabilities: {},
          clientInfo: { name: "cuerail-mcp-read-executor", version: "0" },
        });
        send({ jsonrpc: "2.0", method: "notifications/initialized", params: {} });
        finish(null, await request("tools/call", { name: toolName, arguments: args }));
      } catch (error) {
        finish(error);
      }
    })();
  });
}

(async () => {
  const op = readInput();
  validateReadOp(op);
  const config = codexMcpConfig(op.tool);
  if (config.enabled !== true) {
    die(`Codex MCP server disabled: ${op.tool}${config.disabled_reason ? `: ${config.disabled_reason}` : ""}`);
  }
  try {
    const raw = await callMcp(serverParams(config), op.op, op.input, timeoutMs());
    process.stdout.write(`${JSON.stringify(resultEnvelope(op, "ok", { raw }))}\n`);
  } catch (error) {
    if (error instanceof TimeoutError) {
      process.stdout.write(`${JSON.stringify(resultEnvelope(op, "error", { error: error.message }))}\n`);
      return;
    }
    throw error;
  }
})().catch((error) => die(error.message));
