#!/usr/bin/env sh
set -eu
LC_ALL=C
export LC_ALL

die() {
  printf 'cuerail-review-packet: %s\n' "$1" >&2
  exit 1
}

need() {
  command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

usage() {
  printf 'usage: cuerail-review-packet [--runtime] [--token-usage PATH] [commit]\n' >&2
  exit 2
}

resolve_source_home() {
  case "$0" in
    */*) script_dir=${0%/*} ;;
    *)
      script_path=$(command -v "$0") || die "cannot locate script"
      script_dir=${script_path%/*}
      ;;
  esac

  cd "$script_dir/.." 2>/dev/null && pwd -P
}

status_check() {
  if "$@" >/dev/null 2>&1; then
    printf 'ok'
  else
    printf 'failed'
  fi
}

collect_evidence_surface() {
  dir=$1
  schema=$2
  out=$3

  if [ ! -d "$dir" ]; then
    jq -n '{state: "red", files: []}' >"$out"
    return 0
  fi

  find "$dir" -type f -name '*.json' -print |
    sort |
    while IFS= read -r evidence; do
      jq -e --arg schema "$schema" '
        .schema == $schema and
        (.readiness == "green" or .readiness == "yellow") and
        (.adapter | type == "string") and
        (.kind | type == "string") and
        (.evidence.cacheRel | type == "string")
      ' "$evidence" >/dev/null 2>&1 || continue

      jq -c --arg path "$evidence" '{
        kind,
        path: $path,
        cacheRel: .evidence.cacheRel,
        adapter,
        readiness
      }' "$evidence"
    done |
    jq -s '{
      state: (if any(.[]; .readiness == "green") then "green" elif length > 0 then "yellow" else "red" end),
      files: .
    }' >"$out"
}

runtime_requested=false
token_usage_path=
commit=HEAD

while [ "$#" -gt 0 ]; do
  case "$1" in
    --runtime)
      runtime_requested=true
      shift
      ;;
    --token-usage)
      [ "$#" -ge 2 ] || usage
      token_usage_path=$2
      shift 2
      ;;
    -h|--help)
      usage
      ;;
    -*)
      usage
      ;;
    *)
      [ "$commit" = "HEAD" ] || usage
      commit=$1
      shift
      ;;
  esac
done

case "${CUERAIL_REVIEW_RUNTIME:-}" in
  1|true|yes) runtime_requested=true ;;
esac

CUERAIL_HOME="${CUERAIL_HOME:-$(resolve_source_home)}"
[ -d "$CUERAIL_HOME" ] || die "missing CUERAIL_HOME: $CUERAIL_HOME"
CUERAIL_CACHE="${CUERAIL_CACHE:-$CUERAIL_HOME/cache}"

need git
need jq
need find
need sort

commit_sha=$(git -C "$CUERAIL_HOME" rev-parse --verify "$commit^{commit}") ||
  die "unknown commit: $commit"
parent_sha=$(git -C "$CUERAIL_HOME" rev-parse --verify "$commit_sha^" 2>/dev/null || true)
subject=$(git -C "$CUERAIL_HOME" show -s --format=%s "$commit_sha")
repo_root=$(git -C "$CUERAIL_HOME" rev-parse --show-toplevel)
repo_name=${repo_root##*/}
repo_branch=$(git -C "$CUERAIL_HOME" rev-parse --abbrev-ref HEAD 2>/dev/null || true)
repo_head=$(git -C "$CUERAIL_HOME" rev-parse --short HEAD)
if [ -n "$(git -C "$CUERAIL_HOME" status --porcelain)" ]; then
  repo_dirty=true
else
  repo_dirty=false
fi

changed_files_json=$(mktemp "${TMPDIR:-/tmp}/cuerail-review-files.XXXXXX.json")
line_stats_json=$(mktemp "${TMPDIR:-/tmp}/cuerail-review-stats.XXXXXX.json")
notes_json=$(mktemp "${TMPDIR:-/tmp}/cuerail-review-notes.XXXXXX.json")
git_evidence_json=$(mktemp "${TMPDIR:-/tmp}/cuerail-review-git-evidence.XXXXXX.json")
rg_evidence_json=$(mktemp "${TMPDIR:-/tmp}/cuerail-review-rg-evidence.XXXXXX.json")
token_usage_evidence_json=$(mktemp "${TMPDIR:-/tmp}/cuerail-review-token-usage.XXXXXX.json")
trap 'rm -f "$changed_files_json" "$line_stats_json" "$notes_json" "$git_evidence_json" "$rg_evidence_json" "$token_usage_evidence_json"' EXIT HUP INT TERM

git -C "$CUERAIL_HOME" diff-tree -z --root --no-commit-id --name-only -r "$commit_sha" |
  jq -R -s 'split("\u0000") | map(select(length > 0))' >"$changed_files_json"

git -C "$CUERAIL_HOME" show -z --format= --numstat "$commit_sha" |
  jq -R -s '
    split("\u0000") |
    map(select(length > 0) | split("\t") | {
      path: .[2],
      added: (if .[0] == "-" then null else (.[0] | tonumber) end),
      deleted: (if .[1] == "-" then null else (.[1] | tonumber) end)
    })
  ' >"$line_stats_json"

printf '[]\n' >"$notes_json"

if [ "${CUERAIL_REVIEW_PACKET_SKIP_SOURCE_DOCTOR:-}" = "1" ]; then
  source_doctor_status=skipped
  notes_json_tmp=$notes_json.tmp
  jq '. + ["source doctor skipped by CUERAIL_REVIEW_PACKET_SKIP_SOURCE_DOCTOR"]' "$notes_json" >"$notes_json_tmp"
  mv "$notes_json_tmp" "$notes_json"
else
  source_doctor_status=$(status_check env CUERAIL_REVIEW_PACKET_SKIP_SOURCE_DOCTOR=1 "$CUERAIL_HOME/bin/cuerail-doctor" source)
fi

cue_vet_status=skipped
if command -v cue >/dev/null 2>&1; then
  cue_vet_status=$(status_check sh -c 'cd "$1" && cue vet -c=false ./cue' sh "$CUERAIL_HOME")
else
  notes_json_tmp=$notes_json.tmp
  jq '. + ["cue vet skipped because cue is not available"]' "$notes_json" >"$notes_json_tmp"
  mv "$notes_json_tmp" "$notes_json"
fi

schema_sync_status=skipped
if [ -n "${CODEX_HOME:-}" ] && [ -n "${CODEX_STATE:-}" ] && command -v codex >/dev/null 2>&1; then
  schema_sync_status=$(status_check "$CUERAIL_HOME/bin/cuerail-schema-sync" --check)
else
  notes_json_tmp=$notes_json.tmp
  jq '. + ["schema-sync skipped because CODEX_HOME/CODEX_STATE or codex is unavailable"]' "$notes_json" >"$notes_json_tmp"
  mv "$notes_json_tmp" "$notes_json"
fi

config_schema_sync_status=skipped
if [ -n "${CODEX_HOME:-}" ] && [ -n "${CODEX_STATE:-}" ] && command -v codex >/dev/null 2>&1; then
  config_schema_sync_status=$(status_check "$CUERAIL_HOME/bin/cuerail-config-schema-sync" --check)
else
  notes_json_tmp=$notes_json.tmp
  jq '. + ["config-schema-sync skipped because CODEX_HOME/CODEX_STATE or codex is unavailable"]' "$notes_json" >"$notes_json_tmp"
  mv "$notes_json_tmp" "$notes_json"
fi

runtime_doctor_status=skipped
if [ "$runtime_requested" = "true" ]; then
  runtime_doctor_status=$(status_check "$CUERAIL_HOME/bin/cuerail-doctor" runtime)
else
  notes_json_tmp=$notes_json.tmp
  jq '. + ["runtime doctor skipped by default"]' "$notes_json" >"$notes_json_tmp"
  mv "$notes_json_tmp" "$notes_json"
fi

token_usage_available=false
token_usage_source=
if [ -z "$token_usage_path" ] && [ -f ".cuerail/evidence/token-usage/latest.json" ]; then
  token_usage_path=".cuerail/evidence/token-usage/latest.json"
  token_usage_source=auto
  notes_json_tmp=$notes_json.tmp
  jq '. + ["token usage evidence auto-discovered from latest.json"]' "$notes_json" >"$notes_json_tmp"
  mv "$notes_json_tmp" "$notes_json"
elif [ -n "$token_usage_path" ]; then
  token_usage_source=explicit
fi

if [ -n "$token_usage_path" ] && [ -f "$token_usage_path" ]; then
  jq -e . "$token_usage_path" >"$token_usage_evidence_json" ||
    die "invalid token usage evidence JSON: $token_usage_path"
  token_usage_available=true
fi

collect_evidence_surface "$CUERAIL_CACHE/mcp/git-mcp-go/evidence/repos" "cuerail.git-mcp-go.capture.v1" "$git_evidence_json"
collect_evidence_surface "$CUERAIL_CACHE/mcp/mcp-ripgrep/evidence/search" "cuerail.mcp-ripgrep.search.v1" "$rg_evidence_json"

jq -n \
  --arg commit "$commit_sha" \
  --arg parent "$parent_sha" \
  --arg subject "$subject" \
  --arg repoRoot "$repo_root" \
  --arg repoName "$repo_name" \
  --arg repoBranch "$repo_branch" \
  --arg repoHead "$repo_head" \
  --arg repoDirty "$repo_dirty" \
  --slurpfile changedFiles "$changed_files_json" \
  --slurpfile lineStats "$line_stats_json" \
  --arg sourceDoctor "$source_doctor_status" \
  --arg cueVet "$cue_vet_status" \
  --arg schemaSync "$schema_sync_status" \
  --arg configSchemaSync "$config_schema_sync_status" \
  --arg runtimeDoctor "$runtime_doctor_status" \
  --arg tokenUsagePath "$token_usage_path" \
  --arg tokenUsageAvailable "$token_usage_available" \
  --arg tokenUsageSource "$token_usage_source" \
  --slurpfile gitEvidence "$git_evidence_json" \
  --slurpfile rgEvidence "$rg_evidence_json" \
  --slurpfile tokenUsageEvidence "$token_usage_evidence_json" \
  --slurpfile notes "$notes_json" \
  '
  def source_kind($adapter):
    if ($adapter | startswith("repo-")) then "fallback"
    elif ($adapter | contains("mcp")) then "mcp"
    else "ad_hoc"
    end;
  def sources($surface):
    [($surface.files // [])[] | {
      kind: source_kind(.adapter),
      tool: .adapter,
      readOnly: true,
      adapter: .adapter
    }] | unique_by(.kind, .tool, .adapter);
  def projection($surface):
    if $surface.state == "red" then "red"
    elif (($surface.files // []) | length) > 0 then "green"
    else "yellow"
    end;
  def repo_frame: {
    root: $repoRoot,
    name: $repoName,
    head: $repoHead,
    dirty: ($repoDirty == "true")
  } + (if $repoBranch == "" then {} else {branch: $repoBranch} end);
  {
    commit: $commit,
    parent: (if $parent == "" then null else $parent end),
    subject: $subject,
    changedFiles: $changedFiles[0],
    lineStats: $lineStats[0],
    touched: {
      bin: any($changedFiles[0][]; startswith("bin/")),
      cue: any($changedFiles[0][]; startswith("cue/")),
      cache: any($changedFiles[0][]; startswith("cache/")),
      hooks: any($changedFiles[0][]; contains("hook") or startswith("test/fixtures/hooks/")),
      schemas: any($changedFiles[0][]; contains("schema") or startswith("cue/generated/hooks/")),
      adapters: any($changedFiles[0][]; contains("adapter") or contains("mcp") or . == "bin/repo-git" or . == "bin/repo-rg")
    },
    checks: {
      sourceDoctor: $sourceDoctor,
      cueVet: $cueVet,
      schemaSync: $schemaSync,
      configSchemaSync: $configSchemaSync,
      runtimeDoctor: $runtimeDoctor
    },
    tokenUsage: {
      available: ($tokenUsageAvailable == "true"),
      path: (if $tokenUsagePath == "" then null else $tokenUsagePath end),
      source: (if $tokenUsageSource == "" then null else $tokenUsageSource end)
    } + (if ($tokenUsageAvailable == "true" and ($tokenUsageEvidence | length) > 0)
      then {evidence: $tokenUsageEvidence[0]}
      else {}
      end),
    readSources: {
      git: $gitEvidence[0],
      rg: $rgEvidence[0]
    },
    hookFrames: {
      sessionStart: {
        schema: "cuerail.hook.session-start.v1",
        phase: "session_start",
        repo: repo_frame,
        context: {
          relevantFiles: $changedFiles[0],
          activeSchemas: (if any($changedFiles[0][]; startswith("cue/runtime/")) then ["cue/runtime"] else [] end)
        },
        provenance: [],
        status: {
          captureValidity: $gitEvidence[0].state,
          projectionValidity: projection($gitEvidence[0]),
          sources: sources($gitEvidence[0])
        }
      },
      preToolUse: {
        schema: "cuerail.hook.pre-tool-use.v1",
        phase: "pre_tool_use",
        repo: repo_frame,
        tool: {name: "review-packet"},
        risk: {
          class: (if any($changedFiles[0][]; startswith("bin/")) then "execute" elif any($changedFiles[0][]; startswith("cue/")) then "write" else "unknown" end),
          touchedPaths: $changedFiles[0],
          policySnippets: []
        },
        provenance: [],
        status: {
          captureValidity: (if $rgEvidence[0].state == "red" then $gitEvidence[0].state else $rgEvidence[0].state end),
          projectionValidity: (if projection($rgEvidence[0]) == "red" then projection($gitEvidence[0]) else projection($rgEvidence[0]) end),
          sources: (sources($gitEvidence[0]) + sources($rgEvidence[0]) | unique_by(.kind, .tool, .adapter))
        }
      },
      postToolUse: {
        schema: "cuerail.hook.post-tool-use.v1",
        phase: "post_tool_use",
        repo: repo_frame,
        tool: {name: "review-packet"},
        delta: {
          changedPaths: $changedFiles[0],
          generatedArtifacts: [],
          newEvidence: []
        },
        provenance: [],
        status: {
          captureValidity: $gitEvidence[0].state,
          projectionValidity: projection($gitEvidence[0]),
          sources: sources($gitEvidence[0])
        }
      },
      stop: {
        schema: "cuerail.hook.stop.v1",
        phase: "stop",
        repo: repo_frame,
        summary: {
          unresolvedChanges: $changedFiles[0],
          generatedArtifacts: [],
          validationResults: [
            {name: "sourceDoctor", status: (if $sourceDoctor == "ok" then "green" elif $sourceDoctor == "failed" then "red" else "unknown" end)},
            {name: "cueVet", status: (if $cueVet == "ok" then "green" elif $cueVet == "failed" then "red" else "unknown" end)},
            {name: "schemaSync", status: (if $schemaSync == "ok" then "green" elif $schemaSync == "failed" then "red" else "unknown" end)},
            {name: "runtimeDoctor", status: (if $runtimeDoctor == "ok" then "green" elif $runtimeDoctor == "failed" then "red" else "unknown" end)}
          ]
        },
        provenance: [],
        status: {
          captureValidity: $gitEvidence[0].state,
          projectionValidity: projection($gitEvidence[0]),
          sources: sources($gitEvidence[0])
        }
      }
    },
    notes: $notes[0]
  }'
