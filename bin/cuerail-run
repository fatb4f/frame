#!/usr/bin/env sh
set -eu

die() {
  printf 'cuerail-run: %s\n' "$1" >&2
  exit 1
}

resolve_source_home() {
  case "$0" in
    */*) script_dir=${0%/*} ;;
    *)
      script_path=$(command -v "$0") || die "cannot locate script"
      script_dir=${script_path%/*}
      ;;
  esac

  cd "$script_dir/.." 2>/dev/null && pwd -P
}

quote_arg() {
  printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"
}

command -v script >/dev/null 2>&1 || die "missing required command: script"
command -v codex >/dev/null 2>&1 || die "missing required command: codex"

CUERAIL_HOME="${CUERAIL_HOME:-$(resolve_source_home)}"
[ -x "$CUERAIL_HOME/bin/cuerail-token-usage" ] ||
  die "missing executable bin/cuerail-token-usage"

run_id=$(date -u '+%Y%m%dT%H%M%SZ')
run_dir=".cuerail/runs/$run_id"
runlog="$run_dir/codex.log"
token_json="$run_dir/token-usage.json"
latest_json=".cuerail/evidence/token-usage/latest.json"

mkdir -p "$run_dir" "${latest_json%/*}"

cmd=$(quote_arg codex)
for arg do
  cmd="$cmd $(quote_arg "$arg")"
done

status=0
script -q -e -f -c "$cmd" "$runlog" || status=$?

commit=
if command -v git >/dev/null 2>&1; then
  commit=$(git rev-parse HEAD 2>/dev/null || true)
fi

if [ -n "$commit" ]; then
  "$CUERAIL_HOME/bin/cuerail-token-usage" \
    --from-file "$runlog" \
    --run-id "$run_id" \
    --exit-code "$status" \
    --source-kind codex-script-log \
    --commit "$commit" \
    --output "$token_json" || true
else
  "$CUERAIL_HOME/bin/cuerail-token-usage" \
    --from-file "$runlog" \
    --run-id "$run_id" \
    --exit-code "$status" \
    --source-kind codex-script-log \
    --output "$token_json" || true
fi

cp "$token_json" "$latest_json" 2>/dev/null || true

exit "$status"
