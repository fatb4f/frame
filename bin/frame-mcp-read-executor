#!/usr/bin/env node
const fs = require("node:fs");
const { spawn, spawnSync } = require("node:child_process");

function die(message) {
  process.stderr.write(`frame-mcp-read-executor: ${message}\n`);
  process.exit(1);
}

function readInput() {
  if (process.argv.length > 3) {
    die("usage: frame-mcp-read-executor [READ_OP_JSON]");
  }
  const text = process.argv[2]
    ? fs.readFileSync(process.argv[2], "utf8")
    : fs.readFileSync(0, "utf8");
  try {
    return JSON.parse(text);
  } catch (error) {
    die(`invalid ReadOp JSON: ${error.message}`);
  }
}

function validateReadOp(op) {
  if (op.readOnly !== true) die("ReadOp.readOnly must be true");
  if (op.substrate !== "mcp") die('ReadOp.substrate must be "mcp"');
  if (op.tool !== "mcp-ripgrep" && op.tool !== "git-mcp-server") {
    die(`unsupported MCP tool: ${op.tool}`);
  }
  if (typeof op.op !== "string" || op.op.length === 0) {
    die("ReadOp.op must be a non-empty MCP tool name");
  }
  if (!Object.prototype.hasOwnProperty.call(op, "input")) {
    die("ReadOp.input is required");
  }
}

function codexMcpConfig(name) {
  const result = spawnSync("codex", ["mcp", "get", name, "--json"], {
    encoding: "utf8",
  });
  if (result.status !== 0) {
    die(`missing Codex MCP config for ${name}: ${result.stderr.trim() || result.stdout.trim()}`);
  }
  try {
    return JSON.parse(result.stdout);
  } catch (error) {
    die(`invalid Codex MCP config JSON for ${name}: ${error.message}`);
  }
}

function serverParams(config) {
  const transport = config.transport || {};
  if (transport.type !== "stdio") {
    die(`unsupported MCP transport for ${config.name}: ${transport.type || "missing"}`);
  }
  if (typeof transport.command !== "string" || transport.command.length === 0) {
    die(`missing MCP command for ${config.name}`);
  }
  const env = { ...process.env };
  if (transport.env && typeof transport.env === "object") {
    Object.assign(env, transport.env);
  }
  return {
    command: transport.command,
    args: Array.isArray(transport.args) ? transport.args : [],
    cwd: transport.cwd || undefined,
    env,
  };
}

function callMcp(params, toolName, args) {
  return new Promise((resolve, reject) => {
    const child = spawn(params.command, params.args, {
      cwd: params.cwd,
      env: params.env,
      stdio: ["pipe", "pipe", "pipe"],
    });

    let nextId = 1;
    let stdout = "";
    let stderr = "";
    const pending = new Map();
    let settled = false;

    function finish(error, value) {
      if (settled) return;
      settled = true;
      try {
        child.stdin.end();
      } catch (_) {}
      child.kill();
      error ? reject(error) : resolve(value);
    }

    function send(message) {
      child.stdin.write(`${JSON.stringify(message)}\n`);
    }

    function request(method, paramsValue) {
      const id = nextId++;
      send({ jsonrpc: "2.0", id, method, params: paramsValue });
      return new Promise((resolveRequest, rejectRequest) => {
        pending.set(id, { resolve: resolveRequest, reject: rejectRequest });
      });
    }

    child.stdout.on("data", (chunk) => {
      stdout += chunk.toString("utf8");
      for (;;) {
        const index = stdout.indexOf("\n");
        if (index < 0) break;
        const line = stdout.slice(0, index).replace(/\r$/, "");
        stdout = stdout.slice(index + 1);
        if (!line.trim()) continue;
        let message;
        try {
          message = JSON.parse(line);
        } catch (error) {
          finish(new Error(`MCP server emitted non-JSON stdout: ${line}`));
          return;
        }
        if (!Object.prototype.hasOwnProperty.call(message, "id")) continue;
        const waiter = pending.get(message.id);
        if (!waiter) continue;
        pending.delete(message.id);
        if (message.error) {
          waiter.reject(new Error(JSON.stringify(message.error)));
        } else {
          waiter.resolve(message.result);
        }
      }
    });

    child.stderr.on("data", (chunk) => {
      stderr += chunk.toString("utf8");
    });

    child.on("error", (error) => finish(error));
    child.on("exit", (code) => {
      if (!settled && code !== 0) {
        finish(new Error(`MCP server exited ${code}: ${stderr.trim()}`));
      }
    });

    (async () => {
      try {
        await request("initialize", {
          protocolVersion: "2025-06-18",
          capabilities: {},
          clientInfo: { name: "frame-mcp-read-executor", version: "0" },
        });
        send({ jsonrpc: "2.0", method: "notifications/initialized", params: {} });
        const result = await request("tools/call", {
          name: toolName,
          arguments: args,
        });
        finish(null, result);
      } catch (error) {
        finish(error);
      }
    })();
  });
}

(async () => {
  const op = readInput();
  validateReadOp(op);
  const config = codexMcpConfig(op.tool);
  if (config.enabled !== true) {
    die(`Codex MCP server disabled: ${op.tool}${config.disabled_reason ? `: ${config.disabled_reason}` : ""}`);
  }
  const result = await callMcp(serverParams(config), op.op, op.input);
  process.stdout.write(`${JSON.stringify(result)}\n`);
})().catch((error) => die(error.message));
