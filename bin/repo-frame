#!/usr/bin/env sh
set -eu

usage() {
  cat >&2 <<'USAGE'
usage: repo-frame [ROOT] [GOAL] [QUERY] [MODE] [MAX_RESULTS]

Inputs:
  ROOT         repository/root directory, default: .
  GOAL         turn goal, default: "Observe repository state."
  QUERY        optional rg query to include as search evidence
  MODE         literal | regex, default: literal
  MAX_RESULTS 1..200, default: ${REPO_RG_MAX_RESULTS:-80}

Output:
  JSON shaped as #ContextFrame, projected by CUE from observed repo state.
USAGE
}

json_string() {
  printf '%s' "$1" | awk '
    BEGIN { ORS = ""; first = 1 }
    {
      gsub(/\\/, "\\\\")
      gsub(/"/, "\\\"")
      gsub(/\t/, "\\t")
      if (!first) printf "\\n"
      printf "%s", $0
      first = 0
    }
  '
}

fail() {
  printf 'repo-frame: %s\n' "$1" >&2
  exit 2
}

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
  usage
  exit 0
fi

root=${1:-.}
goal=${2:-Observe repository state.}
query=${3:-}
mode=${4:-${REPO_RG_MODE:-literal}}
max_results=${5:-${REPO_RG_MAX_RESULTS:-80}}

command -v cue >/dev/null 2>&1 || fail "cue not found"
command -v git >/dev/null 2>&1 || fail "git not found"

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd -P)
repo_dir=$(CDPATH= cd -- "$script_dir/.." && pwd -P)
cue_dir="$repo_dir/cue"

root=$(cd "$root" 2>/dev/null && pwd -P) || fail "root does not exist"
git -C "$root" rev-parse --show-toplevel >/dev/null 2>&1 || fail "not inside a git repository"
root=$(git -C "$root" rev-parse --show-toplevel)

git_json=$(repo-git status "$root")
search_json='{"queries":[],"results":[]}'
if [ -n "$query" ]; then
  search_result=$(repo-rg "$query" "$root" "$mode" "$max_results")
  search_json='{"queries":[],"results":['"$search_result"']}'
fi

runtime=$(mktemp "$cue_dir/runtime.XXXXXX.cue")
trap 'rm -f "$runtime"' EXIT HUP INT TERM

{
  printf 'package repo\n\n'
  printf '#RuntimeTurnContext: #TurnContext & {\n'
  printf '\tturn: {\n'
  printf '\t\tcwd: "%s"\n' "$(json_string "$root")"
  printf '\t\tgoal: "%s"\n' "$(json_string "$goal")"
  printf '\t\tinput: [{role: "user", content: "%s"}]\n' "$(json_string "$goal")"
  printf '\t}\n'
  printf '\trepo: {\n'
  printf '\t\troot: "%s"\n' "$(json_string "$root")"
  printf '\t\tgit: %s\n' "$git_json"
  printf '\t\tsearch: %s\n' "$search_json"
  printf '\t}\n'
  printf '\ttask: {\n'
  printf '\t\tkind: "unknown"\n'
  printf '\t\tscope: "%s"\n' "$(json_string "$goal")"
  printf '\t\tconstraints: []\n'
  printf '\t\tunknowns: []\n'
  printf '\t}\n'
  printf '\tbudget: {\n'
  printf '\t\tmaxSearchHits: %s\n' "$max_results"
  printf '\t}\n'
  printf '}\n\n'
  printf '#RuntimeContextFrame: #RuntimeTurnContext.projection\n'
} >"$runtime"

(cd "$repo_dir" && cue export ./cue -e '#RuntimeContextFrame')
