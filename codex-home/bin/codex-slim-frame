#!/usr/bin/env sh
set -eu

export CODEX_HOME="${CODEX_HOME:-$HOME/.local/share/codex}"
export CODEX_STATE="${CODEX_STATE:-$HOME/.local/state/codex}"
export CODEX_CACHE="${CODEX_CACHE:-$HOME/.local/cache/codex}"
export CODEX_SQLITE_HOME="${CODEX_SQLITE_HOME:-$CODEX_STATE/sqlite}"

export PATH="$CODEX_HOME/bin:$HOME/.local/share/path:$HOME/.local/bin:$PATH"

exec codex "$@"

