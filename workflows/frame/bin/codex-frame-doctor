#!/usr/bin/env sh
set -eu

need() {
  command -v "$1" >/dev/null 2>&1 || {
    printf 'missing: %s\n' "$1" >&2
    exit 1
  }
}

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd -P)
repo_dir=$(CDPATH= cd -- "$script_dir/.." && pwd -P)
frame_src=${FRAME_SRC:-$repo_dir}

need repo-frame
need repo-git
need repo-rg
need cue
need rg
need git

if command -v plan-vet >/dev/null 2>&1; then
  plan-vet >/dev/null
fi

if command -v evidence-vet >/dev/null 2>&1; then
  evidence-vet >/dev/null
fi

repo-frame "$frame_src" "Observe repository state." >/dev/null
printf 'codex-frame-doctor: ok\n'

