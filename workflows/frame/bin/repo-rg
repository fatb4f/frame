#!/usr/bin/env sh
set -eu

usage() {
  cat >&2 <<'USAGE'
usage: repo-rg QUERY [ROOT] [MODE] [MAX_RESULTS]

Inputs:
  QUERY        search string
  ROOT         repository/root directory, default: .
  MODE         literal | regex, default: literal
  MAX_RESULTS 1..200, default: ${REPO_RG_MAX_RESULTS:-80}

Output:
  JSON shaped as #RgResult.
USAGE
}

json_string() {
  printf '%s' "$1" | awk '
    BEGIN { ORS = ""; first = 1 }
    {
      gsub(/\\/, "\\\\")
      gsub(/"/, "\\\"")
      gsub(/\t/, "\\t")
      if (!first) printf "\\n"
      printf "%s", $0
      first = 0
    }
  '
}

fail() {
  printf 'repo-rg: %s\n' "$1" >&2
  exit 2
}

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
  usage
  exit 0
fi

[ "$#" -ge 1 ] || { usage; exit 2; }

query=$1
root=${2:-.}
mode=${3:-${REPO_RG_MODE:-literal}}
max_results=${4:-${REPO_RG_MAX_RESULTS:-80}}

case "$mode" in
  literal|regex) ;;
  *) fail "mode must be literal or regex" ;;
esac

case "$max_results" in
  ''|*[!0-9]*) fail "max_results must be an integer" ;;
esac
[ "$max_results" -gt 0 ] || fail "max_results must be > 0"
[ "$max_results" -le 200 ] || fail "max_results must be <= 200"

command -v rg >/dev/null 2>&1 || fail "rg not found"

root=$(cd "$root" 2>/dev/null && pwd -P) || fail "root does not exist"
[ "$root" != "/" ] || fail "refusing to search /"
if [ -n "${HOME:-}" ] && [ "$root" = "$(cd "$HOME" 2>/dev/null && pwd -P)" ]; then
  fail "refusing to search HOME directly; use a repository root"
fi

flags="--line-number --no-heading --color never"
if [ "$mode" = "literal" ]; then
  flags="$flags --fixed-strings"
fi

tmp=$(mktemp)
trap 'rm -f "$tmp"' EXIT HUP INT TERM

# rg exits 1 for no matches; that is still valid evidence.
# shellcheck disable=SC2086
rg $flags -- "$query" "$root" >"$tmp" 2>/dev/null || true

total=$(wc -l <"$tmp" | tr -d ' ')
truncated=false
if [ "$total" -gt "$max_results" ]; then
  truncated=true
fi

printf '{'
printf '"adapter":"rg",'
printf '"query":{'
printf '"root":"%s",' "$(json_string "$root")"
printf '"query":"%s",' "$(json_string "$query")"
printf '"mode":"%s",' "$(json_string "$mode")"
printf '"maxResults":%s' "$max_results"
printf '},'
printf '"matches":['

count=0
while IFS= read -r entry && [ "$count" -lt "$max_results" ]; do
  path=${entry%%:*}
  rest=${entry#*:}
  line=${rest%%:*}
  text=${rest#*:}

  case "$path" in
    "$root"/*) path=${path#"$root"/} ;;
  esac

  case "$line" in
    ''|*[!0-9]*) line=1 ;;
  esac

  [ "$count" -eq 0 ] || printf ','
  printf '{"path":"%s","line":%s,"text":"%s"}' \
    "$(json_string "$path")" \
    "$line" \
    "$(json_string "$text")"
  count=$((count + 1))
done <"$tmp"

printf '],'
printf '"truncated":%s' "$truncated"
printf '}\n'
